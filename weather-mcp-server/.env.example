# Weather MCP Server Configuration
# Copy this file to .env and add your API keys

# OpenWeatherMap API Key (https://openweathermap.org/api)
# Free tier: 60 calls/minute, 1,000,000 calls/month
# OPENWEATHERMAP_API_KEY=your_openweathermap_key_here

# WeatherAPI Key (https://www.weatherapi.com/)
# Free tier: 1,000,000 calls/month, 3-day forecast
# WEATHERAPI_API_KEY=your_weatherapi_key_here

# Visual Crossing API Key (https://www.visualcrossing.com/weather-api)
# Free tier: 1,000 calls/day, 15-day forecast
VISUALCROSSING_API_KEY=BQMA9QWXEFAYMSTJ94NPQBXTS

# Optional: HTTP Proxy (if needed)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080